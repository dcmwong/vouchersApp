# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cloudflare — https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
# Anthropic — https://console.anthropic.com — used to read & categorise vouchers
ANTHROPIC_API_KEY=sk-ant-...

# Headless upload (e.g. iOS Shortcut): a long random secret sent as the
# `x-api-key` header. Uploads via this token are attributed to UPLOAD_USER_ID.
UPLOAD_API_TOKEN=
UPLOAD_USER_ID=   # your Clerk user id (user_...) so Shortcut uploads show in your account

# R2 (create an API token with R2 read/write permissions)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=my-image-app-images
R2_PUBLIC_URL=   # optional: if you have a public bucket or custom domain
